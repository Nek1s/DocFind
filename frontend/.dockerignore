# Зависимости и артефакты сборки — ставятся/собираются внутри образа.
# Без этого `COPY . .` затащит хостовый node_modules (бинарники под ОС хоста)
# и перезатрёт корректные linux-зависимости, установленные через `npm ci`.
node_modules
dist
dist-ssr

# Логи и кеш
*.log
npm-debug.log*
.npm
.cache

# Git и редакторские файлы — в образе не нужны
.git
.gitignore
.vscode
.idea
.DS_Store

# Локальные переменные окружения
*.local
.env
.env.*
